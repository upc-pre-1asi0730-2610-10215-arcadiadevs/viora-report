@startuml VioraApiComponents
!include <C4/C4_Component>

title Component Diagram - API Application

Container_Boundary(apiApp, "API Application") {
    Component(iamContext, "IAM Bounded Context", "ASP.NET Core / Identity", "Handles user authentication, JWT sessions, role management, and access controls.")
    Component(profileContext, "Profile Bounded Context", "ASP.NET Core Service", "Manages details of olive growers and agricultural specialists.")
    Component(agronomicContext, "Agronomic Bounded Context", "ASP.NET Core Service", "Registers productive areas, processes IoT device streams, calculates dynamic nutrition plans, and compiles agronomic stats.")
    Component(surveillanceContext, "Surveillance Bounded Context", "ASP.NET Core Service", "Handles pest sighting reports, symptom definitions, and publishes phytosanitary or community risk alerts.")
    Component(interventionContext, "Intervention Bounded Context", "ASP.NET Core Service", "Coordinates service proposals, matching producers with specialists, intervention tracking, and treatment prescriptions.")
    Component(billingContext, "Billing Bounded Context", "ASP.NET Core Service", "Manages subscription plans, Mercado Pago checkout flow, and the referral/affiliate coupon program.")
    Component(sharedKernel, "Shared Kernel", "C# Shared Module", "Provides shared base classes, transactional pipeline behaviors, and global filters.")
    Component(relationalRepository, "Relational Repository", "EF Core Repository", "Maps domain entities to database tables using Entity Framework Core.")
}

Container(webApp, "Web Application", "Vue.js", "Single-page application used by olive producers and agricultural specialists to manage plots, alerts, interventions and subscriptions.")
ContainerDb(database, "Database", "MySQL", "Stores users, plots, agronomic records, alerts, interventions, subscriptions.")
ContainerDb(mediaStorage, "Media Storage", "Cloudinary-backed media storage", "Stores profile images and related media assets.")

System_Ext(agroMonitoring, "AgroMonitoring API", "External provider of satellite imagery, vegetation indices and agro-weather data.")
System_Ext(mercadoPago, "Mercado Pago", "External payment gateway for subscriptions, renewals, refunds and payment status updates.")
System_Ext(brevo, "Brevo", "Transactional email service for password recovery and account notifications.")
System_Ext(mapbox, "Mapbox", "Maps and geocoding service used for plot delimitation and location-based features.")
System_Ext(cloudinary, "Cloudinary", "Cloud media storage and delivery service for profile images.")

Rel(webApp, iamContext, "Authenticates user and requests session tokens", "JSON/HTTPS")
Rel(webApp, profileContext, "Manages profile information", "JSON/HTTPS")
Rel(webApp, agronomicContext, "Registers plots, IoT devices, and queries stats/nutrition", "JSON/HTTPS")
Rel(webApp, surveillanceContext, "Queries active alerts and reports pest sightings", "JSON/HTTPS")
Rel(webApp, interventionContext, "Coordinates specialist services and tracks interventions", "JSON/HTTPS")
Rel(webApp, billingContext, "Subscribes, views invoices, and redeems coupon codes", "JSON/HTTPS")

Rel(interventionContext, agronomicContext, "Queries plot details and boundaries")
Rel(surveillanceContext, agronomicContext, "Reads plot locations for local risk mapping")

Rel(iamContext, sharedKernel, "Uses")
Rel(profileContext, sharedKernel, "Uses")
Rel(agronomicContext, sharedKernel, "Uses")
Rel(surveillanceContext, sharedKernel, "Uses")
Rel(interventionContext, sharedKernel, "Uses")
Rel(billingContext, sharedKernel, "Uses")

Rel(iamContext, relationalRepository, "Reads/writes identity data")
Rel(profileContext, relationalRepository, "Reads/writes profile data")
Rel(agronomicContext, relationalRepository, "Reads/writes plot, IoT, and stats data")
Rel(surveillanceContext, relationalRepository, "Reads/writes reports and alert records")
Rel(interventionContext, relationalRepository, "Reads/writes intervention and prescription records")
Rel(billingContext, relationalRepository, "Reads/writes subscription and transaction data")

Rel(relationalRepository, database, "Persists and retrieves relational domain data", "ADO.NET")
Rel(relationalRepository, mediaStorage, "Stores and retrieves media asset metadata", "HTTPS/API")

Rel(agronomicContext, agroMonitoring, "Retrieves weather forecast, climate history, and satellite imagery tiles", "HTTPS/JSON")
Rel(agronomicContext, mapbox, "Geocodes boundaries and displays plot mapping UI", "HTTPS/JSON")
Rel(billingContext, mercadoPago, "Processes subscriptions, renewals and processes payment webhooks", "HTTPS/JSON")
Rel(billingContext, brevo, "Sends password recovery, welcome and transactional emails", "HTTPS/API")
Rel(relationalRepository, cloudinary, "Delegates profile images upload", "HTTPS/API")

SHOW_LEGEND()
@enduml
