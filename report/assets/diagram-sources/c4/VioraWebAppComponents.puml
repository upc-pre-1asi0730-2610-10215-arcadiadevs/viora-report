@startuml VioraWebAppComponents
!include <C4/C4_Component>

title Component Diagram - Web Application

Person(oliveProducer, "Olive Producer", "Monitors plots, receives alerts, requests technical interventions and manages subscription.")
Person(agriSpecialist, "Agricultural Specialist", "Publishes professional portfolio, receives cases, evaluates plots and manages interventions.")

Container_Boundary(webApp, "Web Application") {
    Component(iamModule, "IAM Module", "Vue.js Module", "Provides views and components for user login, signup, password recovery, and active session store (Pinia).")
    Component(profileModule, "Profile Module", "Vue.js Module", "Allows producers and specialists to view and update their bios, avatar, and contact profiles.")
    Component(agronomicModule, "Agronomic Module", "Vue.js Module", "Provides views for plot registration, crop type setting, satellite monitoring, IoT device settings, and agronomic statistics.")
    Component(surveillanceModule, "Surveillance Module", "Vue.js Module", "Provides views for pest sighting report filing, symptom history tracking, and active preventive warnings.")
    Component(interventionModule, "Intervention Module", "Vue.js Module", "Coordinates views for searching specialists, sending proposals, tracking intervention execution, and managing treatment prescriptions.")
    Component(billingModule, "Billing Module", "Vue.js Module", "Manages pricing plan selectors, subscription details, payment records, checkout widgets, and referral program views.")
    Component(supportModule, "Support Module", "Vue.js Module", "Displays client support dashboards, frequently asked questions (FAQs), and ticket management components.")
    Component(router, "Router & Guards", "Vue Router", "Manages single-page app routes, transitions, and state-based navigation guards.")
    Component(sharedPresentation, "Shared Presentation Components", "Vue.js Components", "Provides layouts, main workspace wrappers, navigation sidebars, common buttons, and layout primitives.")
    Component(sharedInfrastructure, "Shared Infrastructure Components", "JavaScript / Axios", "Encapsulates Axios API base endpoint configurations, Mapbox services, interceptors, and active session context.")
}

Container(landingPage, "Landing Page", "HTML5, CSS3, JavaScript", "Static website that presents Viora's value proposition, plans, testimonials and calls to action.")
Container(apiApp, "API Application", "ASP.NET Core", "REST API that handles authentication, plot management, agronomic monitoring, surveillance, interventions and billing.")

Rel(oliveProducer, iamModule, "Signs in, registers and recovers account")
Rel(agriSpecialist, iamModule, "Signs in, registers and recovers account")

Rel(oliveProducer, profileModule, "Updates producer profile")
Rel(agriSpecialist, profileModule, "Updates specialist profile")

Rel(oliveProducer, agronomicModule, "Registers plots, monitors satellite data and sets crop properties")
Rel(agriSpecialist, agronomicModule, "Monitors plot details and crop data for assigned cases")

Rel(oliveProducer, surveillanceModule, "Files pest sighting reports and views risk warnings")
Rel(agriSpecialist, surveillanceModule, "Monitors regional warnings and pest sightings")

Rel(oliveProducer, interventionModule, "Searches specialists, accepts proposals, and views prescriptions")
Rel(agriSpecialist, interventionModule, "Submits proposals, tracks milestone progress, and writes prescriptions")

Rel(oliveProducer, billingModule, "Chooses plans, manages trial/subscription, and views invoices")
Rel(oliveProducer, supportModule, "Reads FAQs and requests customer support")
Rel(agriSpecialist, supportModule, "Reads FAQs and requests customer support")

Rel(landingPage, router, "Redirects authenticated users to")

Rel(router, iamModule, "Routes and checks guard authorizations for")
Rel(router, profileModule, "Routes and checks guard authorizations for")
Rel(router, agronomicModule, "Routes and checks guard authorizations for")
Rel(router, surveillanceModule, "Routes and checks guard authorizations for")
Rel(router, interventionModule, "Routes and checks guard authorizations for")
Rel(router, billingModule, "Routes and checks guard authorizations for")
Rel(router, supportModule, "Routes and checks guard authorizations for")

Rel(iamModule, sharedPresentation, "Uses layout and presentation primitives")
Rel(profileModule, sharedPresentation, "Uses layout and presentation primitives")
Rel(agronomicModule, sharedPresentation, "Uses layout and presentation primitives")
Rel(surveillanceModule, sharedPresentation, "Uses layout and presentation primitives")
Rel(interventionModule, sharedPresentation, "Uses layout and presentation primitives")
Rel(billingModule, sharedPresentation, "Uses layout and presentation primitives")
Rel(supportModule, sharedPresentation, "Uses layout and presentation primitives")

Rel(iamModule, sharedInfrastructure, "Makes API requests through")
Rel(profileModule, sharedInfrastructure, "Makes API requests through")
Rel(agronomicModule, sharedInfrastructure, "Makes API requests through")
Rel(surveillanceModule, sharedInfrastructure, "Makes API requests through")
Rel(interventionModule, sharedInfrastructure, "Makes API requests through")
Rel(billingModule, sharedInfrastructure, "Makes API requests through")
Rel(supportModule, sharedInfrastructure, "Makes API requests through")

Rel(sharedInfrastructure, apiApp, "Makes API requests to", "JSON/HTTPS")

SHOW_LEGEND()
@enduml
