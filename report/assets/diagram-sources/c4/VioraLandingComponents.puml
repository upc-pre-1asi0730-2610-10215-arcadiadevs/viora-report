@startuml VioraLandingComponents
!include <C4/C4_Component>

title Component Diagram - Landing Page

Person(visitor, "Visitor", "Explores Viora's landing page, plans, testimonials and calls to action.")


Container_Boundary(landingPage, "Landing Page") {
    Component(landingHeader, "Landing Header Component", "JavaScript ES Module", "Manages the Liquid Glass navigation bar, language selector, and audio toggle.")
    Component(heroSection, "Hero Section Component", "JavaScript ES Module", "Presents the core value proposition and magnetic call-to-action buttons.")
    Component(problemPanel, "Problem Panel Component", "JavaScript ES Module", "Displays the main agronomic and climatic challenges of olive production using interactive cards.")
    Component(problemSolution, "Problem & Solution Section Component", "JavaScript ES Module", "Orchestrates the transition from problem awareness to solutions via video panels and draggable carousels.")
    Component(roleBenefits, "Role Benefits Section Component", "JavaScript ES Module", "Manages the role switcher and segment benefits for producers and agricultural specialists.")
    Component(pricingPlans, "Pricing & Affiliates Component", "JavaScript ES Module", "Presents subscription plans, billing interval switcher, and referral program carousel.")
    Component(aboutTeam, "About & Team Component", "JavaScript ES Module", "Displays the ArcadiaDevs team mission statement, card stack, and floating inspiration bubbles.")
    Component(footerSection, "Footer Section Component", "JavaScript ES Module", "Handles footer navigation, newsletter registration, and Matter.js physics-based badges.")
    Component(landingButton, "Landing Button Component", "JavaScript ES Module", "Shared UI primitive that provides magnetic and audio hover feedback on landing buttons.")
    Component(soundManager, "Sound Manager Service", "JavaScript ES Module", "Coordinates background ambient audio, hover sound triggers, and sound toggles.")
    Component(i18nService, "Internationalization Service", "JavaScript ES Module / JSON", "Loads JSON translations and dynamically swaps text content between English and Spanish.")
    Component(interactionEffects, "Interaction Effects Module", "JavaScript ES Module / GSAP / Lenis", "Provides scroll smoothing (Lenis), magnetic animations, parallax, and infinite marquees.")
}

Container(webApp, "Web Application", "Vue.js", "Single-page application used by olive producers and agricultural specialists to manage plots, alerts, interventions and subscriptions.")

Rel(visitor, landingHeader, "Interacts with navigation, language selector, and audio toggle")
Rel(visitor, heroSection, "Views primary value proposition and clicks CTAs")
Rel(visitor, problemPanel, "Explores agricultural challenges")
Rel(visitor, problemSolution, "Explores solutions and outcomes")
Rel(visitor, roleBenefits, "Explores benefits by role")
Rel(visitor, pricingPlans, "Reviews pricing options and referral benefits")
Rel(visitor, aboutTeam, "Reviews team and mission")
Rel(visitor, footerSection, "Subscribes to newsletter and plays with badges")

Rel(landingHeader, soundManager, "Toggles ambient audio")
Rel(landingHeader, i18nService, "Swaps language key")

Rel(landingHeader, landingButton, "Uses button widgets")
Rel(heroSection, landingButton, "Uses button widgets")
Rel(problemPanel, landingButton, "Uses button widgets")
Rel(problemSolution, landingButton, "Uses button widgets")
Rel(roleBenefits, landingButton, "Uses button widgets")
Rel(pricingPlans, landingButton, "Uses button widgets")
Rel(aboutTeam, landingButton, "Uses button widgets")
Rel(footerSection, landingButton, "Uses button widgets")

Rel(landingButton, soundManager, "Triggers hover sound effect")
Rel(landingButton, interactionEffects, "Uses magnetic effect")

Rel(landingHeader, interactionEffects, "Uses scroll effects")
Rel(heroSection, interactionEffects, "Uses parallax and slide effects")
Rel(problemPanel, interactionEffects, "Uses accordion scroll effects")
Rel(problemSolution, interactionEffects, "Uses carousel drag and video scale effects")
Rel(roleBenefits, interactionEffects, "Uses switcher slide effects")
Rel(pricingPlans, interactionEffects, "Uses toggle slide and carousel effects")
Rel(aboutTeam, interactionEffects, "Uses bubble float and parallax effects")
Rel(footerSection, interactionEffects, "Uses Matter.js physics engine")

Rel(landingHeader, i18nService, "Translates text")
Rel(heroSection, i18nService, "Translates text")
Rel(problemPanel, i18nService, "Translates text")
Rel(problemSolution, i18nService, "Translates text")
Rel(roleBenefits, i18nService, "Translates text")
Rel(pricingPlans, i18nService, "Translates text")
Rel(aboutTeam, i18nService, "Translates text")
Rel(footerSection, i18nService, "Translates text")

Rel(landingHeader, webApp, "Redirects to sign in/up")
Rel(heroSection, webApp, "Redirects to sign in/up/trial")
Rel(pricingPlans, webApp, "Redirects to signup with plan select")
Rel(footerSection, webApp, "Redirects to sign in/up")

SHOW_LEGEND()
@enduml
