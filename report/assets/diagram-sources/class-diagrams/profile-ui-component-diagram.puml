@startuml
package "Profile Management" {
    class ProfileView <<Vue.js Component>> {
        - userProfile: UserProfile
        - isEditing: boolean
        + toggleEditMode()
        + saveChanges()
    }

    class EvidenceUploadWidget <<Vue.js Component>> {
        - selectedFiles: File[]
        + handleFileUpload()
        + uploadEvidence()
    }

    class ProfileStateService {
        + currentProfile: object
        + fetchProfile()
        + updateProfile(data)
        + uploadSpecialistEvidence(files)
    }

    class ProfileApiService {
        + getProfile(userId: int): Promise<Profile>
        + updateProfile(userId: int, data: object): Promise<void>
        + uploadEvidence(userId: int, files: File[]): Promise<void>
    }

    ProfileApiService --|> BaseApiService
    ProfileView *-- EvidenceUploadWidget : contains
    ProfileView --> ProfileStateService : uses
    ProfileStateService --> ProfileApiService : calls
}
@enduml
