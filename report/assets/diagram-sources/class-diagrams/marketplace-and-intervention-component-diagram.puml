@startuml
package "Marketplace & Intervention" {
    class InterventionController {
        - _marketplaceService: IMarketplaceService
        + requestIntervention(dto: RequestInterventionDTO): ResponseEntity<InterventionRequestDTO>
        + acceptCase(requestId: int): ResponseEntity<Void>
        + rejectCase(requestId: int): ResponseEntity<Void>
        + getRequestDetails(requestId: int): ResponseEntity<InterventionDetailDTO>
    }

    interface IMarketplaceService {
        + findSpecialists(criteria: FilterDTO): List<SpecialistDTO>
        + createRequest(dto: RequestInterventionDTO): InterventionRequest
        + updateRequestStatus(id: int, status: RequestStatus): void
        + getRequestDetails(id: int): InterventionDetailDTO
    }

    class MarketplaceService {
        - _requestRepo: IBaseRepository<InterventionRequest>
        - _brevoClient: IBrevoClient
        + findSpecialists()
        + createRequest()
        + updateRequestStatus()
        + getRequestDetails()
    }

    class InterventionRequest <<Entity>> {
        + Id: int
        + ProducerId: int
        + PlotId: int
        + SpecialistId: int
        + Status: RequestStatus
        + Description: String
        + ScheduledDate: LocalDateTime
        + CreatedAt: LocalDateTime
    }

    class Quotation <<Entity>> {
        + Id: int
        + InterventionRequestId: int
        + ProposedAmount: decimal
        + Notes: String
        + IsAccepted: bool
    }

    class TechnicalPrescription <<Entity>> {
        + Id: int
        + InterventionRequestId: int
        + Diagnosis: String
        + Recommendations: String
        + IssuedAt: LocalDateTime
    }

    enum RequestStatus {
        Pending
        Accepted
        Rejected
        InProgress
        Completed
        Cancelled
    }

    IMarketplaceService <|.. MarketplaceService
    MarketplaceService --> IBaseRepository : uses
    InterventionController --> IMarketplaceService : depends on
    InterventionRequest "*" -- "1" Plot : targets
    InterventionRequest "*" -- "1" User : requested by (Producer)
    InterventionRequest "*" -- "1" User : assigned to (Specialist)
    Quotation "0..1" --* "1" InterventionRequest : belongs to
    TechnicalPrescription "0..1" --* "1" InterventionRequest : issued for
}
@enduml
