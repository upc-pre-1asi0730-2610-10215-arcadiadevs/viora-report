@startuml
package "API Client Services" {
    class AxiosHttpClient {
        - baseUrl: string
        + addRequestInterceptors()
        + addResponseInterceptors()
        + get(url: string, config?: AxiosRequestConfig): Promise<AxiosResponse>
        + post(url: string, data?: unknown): Promise<AxiosResponse>
        + put(url: string, data?: unknown): Promise<AxiosResponse>
        + delete(url: string): Promise<AxiosResponse>
    }

    class BaseApiService {
        # httpClient: AxiosHttpClient
        + constructor(client: AxiosHttpClient)
        # handleResponse<T>(resp: AxiosResponse<T>): T
        # handleError(error: AxiosError): void
    }
}

package "Shared UI Components" {
    class BaseLayout <<Vue.js Component>> {
        + isSidebarOpen: boolean
        + toggleSidebar()
    }

    class DataTableWidget <<Vue.js Component>> {
        + columns: Column[]
        + rows: Row[]
        + pageSize: number
        + onSort(column: string)
        + onPaginate(page: number)
    }

    class BaseModalWidget <<Vue.js Component>> {
        + isVisible: boolean
        + title: string
        + open()
        + close()
        + emitConfirm()
    }

    class LoadingSpinnerWidget <<Vue.js Component>> {
        + isActive: boolean
        + message: string
    }
}

BaseApiService --> AxiosHttpClient : uses
@enduml
